#!/usr/bin/env bash

# Resolve the directory where this script lives
if [ -n "$BASH_VERSION" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
elif [ -n "$ZSH_VERSION" ]; then
    SCRIPT_DIR="$(cd "$(dirname "${(%):-%N}")" && pwd)"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
fi

ZDE_HOME="$(cd "$SCRIPT_DIR/.." && pwd)/home"

set_vars() {
    cat <<EOF
export ZDE_HOME="$ZDE_HOME"
export ZDE_PATH="\$ZDE_HOME/.."

_zde_managed_env_file="\${ZDE_USER_PATH:-\$HOME/.zeal8bit}/deps.env"
if [ -f "\$_zde_managed_env_file" ]; then
    while IFS= read -r _zde_line || [ -n "\$_zde_line" ]; do
        case "\$_zde_line" in
            ""|\#*)
                continue
                ;;
        esac

        _zde_key="\${_zde_line%%=*}"
        _zde_value="\${_zde_line#*=}"
        case "\$_zde_value" in
            /home/zeal8bit)
                _zde_value="\$ZDE_HOME"
                ;;
            /home/zeal8bit/*)
                _zde_value="\$ZDE_HOME\${_zde_value#/home/zeal8bit}"
                ;;
        esac
        export "\$_zde_key=\$_zde_value"
    done < "\$_zde_managed_env_file"
fi

export PATH="\$ZDE_PATH:\$PATH"
if [ -n "\${ZOS_PATH:-}" ]; then export PATH="\$ZOS_PATH/tools:\$PATH"; fi
if [ -n "\${ZVB_SDK_PATH:-}" ]; then export PATH="\$ZVB_SDK_PATH/tools/zeal2gif:\$PATH"; fi
if [ -n "\${ZVB_SDK_PATH:-}" ]; then export PATH="\$ZVB_SDK_PATH/tools/tiled2zeal:\$PATH"; fi
if [ -n "\${ZAR_PATH:-}" ]; then export PATH="\$ZAR_PATH:\$PATH"; fi

unset _zde_managed_env_file _zde_line _zde_key _zde_value
EOF
}

# If we are sourced, apply directly.
# If not, just print so it can be used with eval.
if [ "${BASH_SOURCE[0]}" != "$0" ] || [ -n "$ZSH_EVAL_CONTEXT" ]; then
    eval "$(set_vars)"
else
    set_vars
fi
