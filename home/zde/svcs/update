#!/bin/bash

set -euo pipefail

CURRENT_BRANCH="$(git -C "$ZDE_PATH" branch --show-current 2>/dev/null || true)"

if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "Pulling latest Zeal 8-bit repository branch: main"
  git -C "$ZDE_PATH" pull origin main
else
  if [ -z "$CURRENT_BRANCH" ]; then
    echo "Skipping ZDE git pull (detached HEAD; not on main)"
  else
    echo "Skipping ZDE git pull (current branch: $CURRENT_BRANCH)"
  fi
fi

"$CONTAINER_CMD" image pull "$ZDE_IMAGE_REF"

source "$ZDE_PATH/home/zde/svcs/common.sh"
zde_init update "$@" || exit 1
zde_command update "$@"
