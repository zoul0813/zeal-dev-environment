#!/bin/bash

set -euo pipefail

ZDE_BRANCH="${ZDE_BRANCH:-$(git -C "$ZDE_PATH" branch --show-current 2>/dev/null || true)}"

if [ -z "$ZDE_BRANCH" ]; then
  echo "Unable to determine current ZDE branch (detached HEAD)."
  echo "Set ZDE_BRANCH explicitly to run update, e.g. ZDE_BRANCH=main zde update"
  exit 1
fi

echo "Pulling latest Zeal 8-bit repository branch: $ZDE_BRANCH"
git -C "$ZDE_PATH" pull origin "$ZDE_BRANCH"

"$CONTAINER_CMD" image pull "$ZDE_IMAGE_REF"

echo "Running in-container update tasks"
source "$ZDE_PATH/home/zde/svcs/common.sh"
zde_init update "$@" || exit 1
zde_command update "$@"
