#!/bin/bash

set +x

ZDE_PATH=$(dirname "$0")
source "$ZDE_PATH/home/zde/svcs/common.sh"
zde_init "$@" || exit 1

finalize_exit() {
  local rc="$1"
  # In interactive terminals, ZDE already prints actionable errors.
  # Returning 0 avoids outer wrappers printing redundant "Error: executing ..." noise.
  # Set ZDE_STRICT_EXIT=1 to preserve non-zero exit codes interactively.
  if [ "$rc" -ne 0 ] && [ -t 1 ] && [ "${ZDE_STRICT_EXIT:-0}" != "1" ]; then
    exit 0
  fi
  exit "$rc"
}

zde_version() {
  local short_sha=""
  local exact_tag=""
  local base_tag=""

  short_sha="$(git -C "$ZDE_PATH" rev-parse --short=7 HEAD 2>/dev/null || true)"
  if [ -z "$short_sha" ]; then
    echo "unversioned"
    return 0
  fi

  exact_tag="$(git -C "$ZDE_PATH" describe --tags --exact-match 2>/dev/null || true)"
  if [ -n "$exact_tag" ]; then
    echo "$exact_tag"
    return 0
  fi

  base_tag="$(git -C "$ZDE_PATH" describe --tags --abbrev=0 2>/dev/null || true)"
  if [ -n "$base_tag" ]; then
    echo "${base_tag}-${short_sha}"
    return 0
  fi

  echo "$short_sha"
}

print_version_info() {
  local image_tags=""
  local image_repo=""
  local escaped_repo=""
  echo "ZDE: $(zde_version)"
  echo "Image: $ZDE_IMAGE_REF"

  image_repo="${ZDE_IMAGE_REF%%:*}"
  image_tags="$("$CONTAINER_CMD" image inspect "$ZDE_IMAGE_REF" --format '{{range .RepoTags}}{{println .}}{{end}}' 2>/dev/null || true)"
  if [ -z "$image_tags" ]; then
    image_tags="$("$CONTAINER_CMD" image inspect "docker.io/$ZDE_IMAGE_REF" --format '{{range .RepoTags}}{{println .}}{{end}}' 2>/dev/null || true)"
  fi
  if [ -z "$image_tags" ]; then
    escaped_repo="$(printf '%s' "$image_repo" | sed 's/[.[\*^$()+?{|]/\\&/g')"
    image_tags="$("$CONTAINER_CMD" images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null | grep -E "^(docker\\.io/)?${escaped_repo}:" || true)"
  fi

  if [ -n "$image_tags" ]; then
    echo "Image tags:"
    while IFS= read -r tag; do
      [ -n "$tag" ] || continue
      echo "  - $tag"
    done <<< "$(printf '%s\n' "$image_tags" | awk '!seen[$0]++')"
  else
    echo "Image tags: (image not present locally)"
  fi
}

print_service_statuses() {
  local green=""
  local reset=""
  if [ -t 1 ]; then
    green=$'\033[32m'
    reset=$'\033[0m'
  fi

  print_service_line() {
    local label="$1"
    local container_name="$2"
    local status
    status="$(container_status_name "$container_name")"
    if [ "$status" = "running" ]; then
      echo "  * ${green}${label}${reset} [start|stop|status]"
    else
      echo "    ${label} [start|stop|status]"
    fi
  }

  echo "Services:"
  print_service_line "emulator" "zeal8bit-emulator"
  print_service_line "playground" "zeal8bit-playground"
}

case "$COMMAND" in
  -v|--version|version)
    print_version_info
    exit 0
    ;;
  -i)
    if [ "${HOST_ARGS[0]-}" = "-b" ]; then
      zde_shell "${ZDE_BUILD_SERVICE:-zeal8bit-build-env}"
    else
      zde_shell "$CONTAINER_SERVICE"
    fi
    finalize_exit $?
    ;;
  exec)
    if [ "${#HOST_ARGS[@]}" -eq 0 ]; then
      echo "Usage: zde exec <command> [args...]"
      exit 1
    fi
    zde_exec "${HOST_ARGS[@]}"
    finalize_exit $?
    ;;
  activate)
    if [ -t 1 ]; then
      echo "⚠️  This script must be run with: eval \"\$(zde activate)\"" >&2
    else
      "$ZDE_PATH/bin/activate"
    fi
    exit 0
    ;;
  emu|emulator)
    "$ZDE_PATH/home/zde/svcs/emulator" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  playground)
    "$ZDE_PATH/home/zde/svcs/playground" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  update)
    "$ZDE_PATH/home/zde/svcs/update" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  rebuild)
    echo "Host-only command pending reimplementation in /zde: $COMMAND"
    echo "TODO(host): implement $COMMAND in this bash wrapper."
    exit 1
    ;;
esac

if [ -z "$COMMAND" ] || [ "$COMMAND" = "help" ]; then
  zde_command "$@"
  rc=$?
  print_service_statuses
  finalize_exit $rc
fi

zde_command "$@"
finalize_exit $?
