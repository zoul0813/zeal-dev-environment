#!/bin/bash

set +x

ZDE_PATH=$(dirname "$0")
source "$ZDE_PATH/home/zde/svcs/common.sh"
zde_init "$@" || exit 1

finalize_exit() {
  local rc="$1"
  # In interactive terminals, ZDE already prints actionable errors.
  # Returning 0 avoids outer wrappers printing redundant "Error: executing ..." noise.
  # Set ZDE_STRICT_EXIT=1 to preserve non-zero exit codes interactively.
  if [ "$rc" -ne 0 ] && [ -t 1 ] && [ "${ZDE_STRICT_EXIT:-0}" != "1" ]; then
    exit 0
  fi
  exit "$rc"
}

case "$COMMAND" in
  -i)
    if [ "${HOST_ARGS[0]-}" = "-b" ]; then
      zde_shell "${ZDE_BUILD_SERVICE:-zeal8bit-build-env}"
    else
      zde_shell "$CONTAINER_SERVICE"
    fi
    finalize_exit $?
    ;;
  activate)
    if [ -t 1 ]; then
      echo "⚠️  This script must be run with: eval \"\$(zde activate)\"" >&2
    else
      "$ZDE_PATH/bin/activate"
    fi
    exit 0
    ;;
  emu|emulator)
    "$ZDE_PATH/home/zde/svcs/emulator" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  playground)
    "$ZDE_PATH/home/zde/svcs/playground" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  update)
    "$ZDE_PATH/home/zde/svcs/update" "${HOST_ARGS[@]-}"
    finalize_exit $?
    ;;
  rebuild)
    echo "Host-only command pending reimplementation in /zde: $COMMAND"
    echo "TODO(host): implement $COMMAND in this bash wrapper."
    exit 1
    ;;
esac

zde_command "$@"
finalize_exit $?
