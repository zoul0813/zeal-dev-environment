#!/bin/bash

set +x

ZDE_PATH=$(dirname "$0")
COMPOSE_PATH="$ZDE_PATH/docker-compose.yml"
CONTAINER_SERVICE=zeal8bit-dev-env
ZDE_USER_PATH="${ZDE_USER_PATH:-$HOME/.zeal8bit}"
mkdir -p "$ZDE_USER_PATH"

export ZDE_IMAGE=${ZDE_IMAGE:-zoul0813/zeal-dev-environment}
export ZDE_VERSION=${ZDE_VERSION:-latest}

if command -v docker >/dev/null 2>&1; then
  CONTAINER_CMD=docker
elif command -v podman >/dev/null 2>&1; then
  CONTAINER_CMD=podman
else
  echo "WARNING: docker/podman not found, ensure docker or podman is installed before using ZDE"
  exit 1
fi

HOST_UID=$(id -u)
HOST_GID=$(id -g)

ZEAL_KERNEL_VERSION=$(git -C "$ZDE_PATH/home/Zeal-8-bit-OS" describe --tags 2>/dev/null || true)
COMMAND="$1"
HOST_ARGS=("${@:2}")

ZDE_IMAGE_REF="${ZDE_IMAGE}:${ZDE_VERSION}"
LAUNCH_PWD="$PWD"

export CONTAINER_CMD
export ZDE_PATH
export ZDE_IMAGE_REF
export HOST_UID
export HOST_GID
export LAUNCH_PWD

case "$COMMAND" in
  activate)
    if [ -t 1 ]; then
      echo "⚠️  This script must be run with: eval \"\$(zde activate)\"" >&2
    else
      "$ZDE_PATH/bin/activate"
    fi
    exit 0
    ;;
  emu|emulator)
    "$ZDE_PATH/home/zde/svcs/emulator" "${HOST_ARGS[@]}"
    exit $?
    ;;
  playground)
    "$ZDE_PATH/home/zde/svcs/playground" "${HOST_ARGS[@]}"
    exit $?
    ;;
  update)
    "$ZDE_PATH/home/zde/svcs/update" "${HOST_ARGS[@]}"
    exit $?
    ;;
  start|stop|restart|status)
    echo "Command removed: $COMMAND"
    echo "ZDE now runs containers/services on demand and manages lifecycle automatically."
    exit 1
    ;;
  rebuild)
    echo "Host-only command pending reimplementation in /zde: $COMMAND"
    echo "TODO(host): implement $COMMAND in this bash wrapper."
    exit 1
    ;;
esac

CONTAINER_EXEC=(
  "$CONTAINER_CMD" compose -f "$COMPOSE_PATH" run -i --rm
  -e "HOST_UID=${HOST_UID}"
  -e "HOST_GID=${HOST_GID}"
)

if [ -n "$ZEAL_KERNEL_VERSION" ]; then
  CONTAINER_EXEC+=( -e "ZEAL_KERNEL_VERSION=${ZEAL_KERNEL_VERSION}" )
fi

"${CONTAINER_EXEC[@]}" "$CONTAINER_SERVICE" /home/zeal8bit/zde/zde.py "$@"
